// modelInfo holds type-specific conversion functions.
// Passed directly to builder - no registry lookup needed.
type modelInfo[M any] struct {
	// UnmarshalAll unmarshals query results into []*M
	UnmarshalAll func(data []byte) ([]*M, error)

	// UnmarshalOne unmarshals a single result into *M
	UnmarshalOne func(data []byte) (*M, error)

	// UnmarshalSearchAll unmarshals search query results into []SearchResult[*M]
	UnmarshalSearchAll func(data []byte, clauses []lib.SearchClause) ([]lib.SearchResult[*M], error)
}

type rangeFn[M any] func(q *lib.Query[M], from som.RangeFrom, to som.RangeTo) string

// M is a placeholder for the model type.
// S is the select builder type, provided by codegen for each model.
type builder[M, S any] struct {
	db       Database
	query    lib.Query[M]
	info     modelInfo[M]
	rangeFn  rangeFn[M]
	selectFn func(Database, lib.Query[M]) S
}

type Builder[M, S any] struct {
	builder[M, S]
}

type BuilderNoLive[M, S any] struct {
	builder[M, S]
}

// Where adds a where statement to the query to
// select records based on the given conditions.
//
// Use filter.All to chain multiple conditions
// together that all need to match.
// Use filter.Any to chain multiple conditions
// together where at least one needs to match.
func (b builder[M, S]) Where(filters ...lib.Filter[M]) Builder[M, S] {
	b.query.Where = append(b.query.Where, filters...)
	return Builder[M, S]{b}
}

// WithDeleted allows querying soft-deleted records.
// By default, soft-deleted records are automatically filtered out.
// This method only has an effect on models with SoftDelete enabled.
func (b builder[M, S]) WithDeleted() Builder[M, S] {
	b.query.IncludeDeleted = true
	return Builder[M, S]{b}
}

// Range restricts the query to a range of record IDs.
// This uses SurrealDB's native range syntax (e.g. table:start..end)
// which avoids table scans and is much more performant than WHERE filters.
// Only available for models with complex IDs (ArrayID/ObjectID).
func (b builder[M, S]) Range(from som.RangeFrom, to som.RangeTo) BuilderNoLive[M, S] {
	if b.rangeFn != nil {
		b.query.RangeExpr = b.rangeFn(&b.query, from, to)
	}
	return BuilderNoLive[M, S]{b}
}

// Order sorts the returned records based on the given conditions.
// If multiple conditions are given, they are applied one after the other.
// Note: If OrderRandom is used within the same query,
// it would override the sort conditions.
func (b builder[M, S]) Order(by ...*lib.Sort[M]) BuilderNoLive[M, S] {
	for _, s := range by {
		b.query.Sort = append(b.query.Sort, (*lib.SortBuilder)(s))
	}
	return BuilderNoLive[M, S]{b}
}

// OrderRandom sorts the returned records in a random order.
// Note: OrderRandom takes precedence over Order.
func (b builder[M, S]) OrderRandom() BuilderNoLive[M, S] {
	b.query.SortRandom = true
	return BuilderNoLive[M, S]{b}
}

// Start skips the first x records for the result set.
func (b builder[M, S]) Start(start int) BuilderNoLive[M, S] {
	b.query.Start = start
	return BuilderNoLive[M, S]{b}
}

// Limit restricts the query to return at most x records.
func (b builder[M, S]) Limit(limit int) BuilderNoLive[M, S] {
	b.query.Limit = limit
	return BuilderNoLive[M, S]{b}
}

// Fetch can be used to return related records.
// This works for both record links and edges.
// Note: Soft-delete filtering does not apply to fetched relations.
// All related records are returned regardless of their soft-delete status.
func (b builder[M, S]) Fetch(fetch ...with.Fetch_[M]) Builder[M, S] {
	for _, f := range fetch {
		field := fmt.Sprintf("%v", f)
		if field != "" {
			b.query.Fetch = append(b.query.Fetch, field)
		}
	}
	return Builder[M, S]{b}
}

// Timeout adds an execution time limit to the query.
// When exceeded, the query call will return with an error.
func (b builder[M, S]) Timeout(timeout time.Duration) BuilderNoLive[M, S] {
	b.query.Timeout = timeout
	return BuilderNoLive[M, S]{b}
}

// Parallel tells SurrealDB that individual parts
// of the query can be calculated in parallel.
// This could lead to a faster execution.
func (b builder[M, S]) Parallel(parallel bool) BuilderNoLive[M, S] {
	b.query.Parallel = parallel
	return BuilderNoLive[M, S]{b}
}

// TempFiles tells SurrealDB to process the query using temporary files
// rather than memory. This reduces memory usage for large result sets
// at the cost of slower performance.
func (b builder[M, S]) TempFiles(tempFiles bool) BuilderNoLive[M, S] {
	b.query.TempFiles = tempFiles
	return BuilderNoLive[M, S]{b}
}

// Select returns a model-specific select builder that allows
// selecting individual field values from the query results.
func (b builder[M, S]) Select() S {
	return b.selectFn(b.db, b.query)
}

// Count returns the size of the result set, in other words, the
// number of records matching the conditions of the query.
func (b builder[M, S]) Count(ctx context.Context) (int, error) {
	req := b.query.BuildAsCount()
	raw, err := b.db.Query(ctx, req.Statement, req.Variables)
	if err != nil {
		return 0, err
	}
	var rawCount []internal.QueryResult[countResult]
	err = cbor.Unmarshal(raw, &rawCount)
	if err != nil {
		return 0, fmt.Errorf("could not count records: %w", err)
	}
	if len(rawCount) < 1 || len(rawCount[0].Result) < 1 {
		return 0, nil
	}
	return rawCount[0].Result[0].Count, nil
}

// CountAsync is the asynchronous version of Count.
func (b builder[M, S]) CountAsync(ctx context.Context) *asyncResult[int] {
	return async(ctx, b.Count)
}

// Exists returns whether at least one record for the conditions
// of the query exists or not. In other words, it returns whether
// the size of the result set is greater than 0.
func (b builder[M, S]) Exists(ctx context.Context) (bool, error) {
	count, err := b.Count(ctx)
	if err != nil {
		return false, err
	}
	return count > 0, nil
}

// ExistsAsync is the asynchronous version of Exists.
func (b builder[M, S]) ExistsAsync(ctx context.Context) *asyncResult[bool] {
	return async(ctx, b.Exists)
}

// All returns all records matching the conditions of the query.
func (b builder[M, S]) All(ctx context.Context) ([]*M, error) {
	req := b.query.BuildAsAll()
	res, err := b.db.Query(ctx, req.Statement, req.Variables)
	if err != nil {
		return nil, fmt.Errorf("could not query records: %w", err)
	}
	return b.info.UnmarshalAll(res)
}

// AllAsync is the asynchronous version of All.
func (b builder[M, S]) AllAsync(ctx context.Context) *asyncResult[[]*M] {
	return async(ctx, b.All)
}

// AllIDs returns the IDs of all records matching the conditions of the query.
func (b builder[M, S]) AllIDs(ctx context.Context) ([]string, error) {
	req := b.query.BuildAsAllIDs()
	res, err := b.db.Query(ctx, req.Statement, req.Variables)
	if err != nil {
		return nil, fmt.Errorf("could not query records: %w", err)
	}
	var rawNodes []internal.QueryResult[idNode]
	err = cbor.Unmarshal(res, &rawNodes)
	if err != nil {
		return nil, fmt.Errorf("could not unmarshal records: %w", err)
	}
	if len(rawNodes) < 1 {
		return nil, nil
	}
	var ids []string
	for _, rawNode := range rawNodes[0].Result {
		ids = append(ids, rawNode.ID.String())
	}
	return ids, nil
}

// AllIDsAsync is the asynchronous version of AllIDs.
func (b builder[M, S]) AllIDsAsync(ctx context.Context) *asyncResult[[]string] {
	return async(ctx, b.AllIDs)
}

// First returns the first record matching the conditions of the query.
// This comes in handy when using a filter for a field with unique values or when
// sorting the result set in a specific order where only the first result is relevant.
func (b builder[M, S]) First(ctx context.Context) (*M, error) {
	b.query.Limit = 1
	res, err := b.All(ctx)
	if err != nil {
		return nil, err
	}
	if len(res) < 1 {
		return nil, som.ErrNotFound
	}
	return res[0], nil
}

// FirstAsync is the asynchronous version of First.
func (b builder[M, S]) FirstAsync(ctx context.Context) *asyncResult[*M] {
	return async(ctx, b.First)
}

// FirstID returns the ID of the first record matching the conditions of the query.
// This comes in handy when using a filter for a field with unique values or when
// sorting the result set in a specific order where only the first result is relevant.
func (b builder[M, S]) FirstID(ctx context.Context) (string, error) {
	b.query.Limit = 1
	res, err := b.AllIDs(ctx)
	if err != nil {
		return "", err
	}
	if len(res) < 1 {
		return "", som.ErrNotFound
	}
	return res[0], nil
}

// FirstIDAsync is the asynchronous version of FirstID.
func (b builder[M, S]) FirstIDAsync(ctx context.Context) *asyncResult[string] {
	return async(ctx, b.FirstID)
}

// Iterate returns an iterator that yields records in batches.
// The batchSize parameter controls how many records are fetched per database query.
// Iteration stops on the first error encountered.
func (b builder[M, S]) Iterate(ctx context.Context, batchSize int) iter.Seq2[*M, error] {
	return func(yield func(*M, error) bool) {
		start := b.query.Start

		for {
			batchBuilder := b
			batchBuilder.query.Limit = batchSize
			batchBuilder.query.Start = start

			results, err := batchBuilder.All(ctx)
			if err != nil {
				yield(nil, err)
				return
			}

			if len(results) == 0 {
				return
			}

			for _, node := range results {
				if !yield(node, nil) {
					return
				}
			}

			if len(results) < batchSize {
				return
			}

			start += batchSize
		}
	}
}

// IterateID returns an iterator that yields record IDs in batches.
// The batchSize parameter controls how many IDs are fetched per database query.
// Iteration stops on the first error encountered.
func (b builder[M, S]) IterateID(ctx context.Context, batchSize int) iter.Seq2[string, error] {
	return func(yield func(string, error) bool) {
		start := b.query.Start

		for {
			batchBuilder := b
			batchBuilder.query.Limit = batchSize
			batchBuilder.query.Start = start

			ids, err := batchBuilder.AllIDs(ctx)
			if err != nil {
				yield("", err)
				return
			}

			if len(ids) == 0 {
				return
			}

			for _, id := range ids {
				if !yield(id, nil) {
					return
				}
			}

			if len(ids) < batchSize {
				return
			}

			start += batchSize
		}
	}
}

// Live registers the constructed query as a live query.
// Whenever something in the database changes that matches the
// query conditions, the result channel will receive an update.
// If the context is canceled, a best-effort attempt is made to kill
// the live query on the server and the result channel will be closed.
//
// Note: If you want both the current result set and live updates,
// it is advised to execute the live query first. This is to ensure
// data consistency. The other way around, there could be missing
// updates happening between the initial query and the live query.
func (b Builder[M, S]) Live(ctx context.Context) (<-chan LiveResult[*M], error) {
	req := b.query.BuildAsLive()
	resChan, err := b.db.Live(ctx, req.Statement, req.Variables)
	if err != nil {
		return nil, fmt.Errorf("failed to query live records: %w", err)
	}
	return live(ctx, resChan, b.info), nil
}

// LiveCount is the live version of Count.
// Whenever a record is created or deleted that matches the
// conditions of the query, the count will be updated.
func (b Builder[M, S]) LiveCount(ctx context.Context) (<-chan int, error) {
	count, err := b.Count(ctx)
	if err != nil {
		return nil, fmt.Errorf("failed to execute initial count: %w", err)
	}

	resChan, err := b.Live(ctx)
	if err != nil {
		return nil, fmt.Errorf("failed to execute live query: %w", err)
	}

	countChan := make(chan int, 1)
	countChan <- count

	go func() {
		defer close(countChan)

		for {
			select {

			case <-ctx.Done():
				return

			case res, ok := <-resChan:
				if !ok {
					return
				}

				switch res.(type) {

				case LiveCreate[*M]:
					count++

				case LiveDelete[*M]:
					count--

				case LiveKilled[*M]:
					return

				default:
					continue
				}

				select {
				case <-ctx.Done():
					return
				case countChan <- count:
				}
			}
		}
	}()

	return countChan, nil
}

