// ErrTransactionClosed is returned when attempting to use a transaction that
// has already been committed or canceled.
var ErrTransactionClosed = internal.ErrTxClosed

// ErrTransactionAlreadyActive is returned (as a panic) when TxStart
// is called on a context that already has an active transaction.
var ErrTransactionAlreadyActive = internal.ErrTxAlreadyActive

// ErrLiveNotSupportedInTx is returned when a live query is attempted
// within a transaction context.
var ErrLiveNotSupportedInTx = internal.ErrTxLiveNotSupported
