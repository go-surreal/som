//go:build embed

package define

import (
	"reflect"

	"{{.GenerateOutPath}}/internal/lib"
)

// ViewDefinition is the non-generic interface stored in Definitions.Views.
type ViewDefinition interface {
	viewDef() viewDefJSON
}

// ViewBuilder builds a read-only view definition (DEFINE TABLE ... AS SELECT).
// V is the view model, T the source model the view selects from.
type ViewBuilder[V any, T any] struct {
	projections []string
	where       string
	groupBy     []string
}

// View starts a new read-only view definition selecting from source model T
// into view model V. The database table names are derived from the model
// types during code generation.
func View[V any, T any]() *ViewBuilder[V, T] {
	return &ViewBuilder[V, T]{}
}

// Projection is a single "<expr> AS <column>" entry of a view. It carries
// both the view model V (the projected column) and the source model T (the
// expression), so a builder only accepts projections that match its own
// V and T.
type Projection[V any, T any] struct {
	render string
}

// As projects a source expression (a filter field or an aggregate over one)
// into a view column (a filter field of the view model). The view model V is
// inferred from the column and the source model T from the expression.
func As[V any, T any](column lib.KeyProvider[V], expr lib.KeyProvider[T]) Projection[V, T] {
	return Projection[V, T]{render: lib.RenderProjection(expr) + " AS " + lib.RenderProjection(column)}
}

// Project sets the columns the view computes from the source rows. Only
// projections whose column belongs to V and whose expression comes from T
// are accepted.
func (b *ViewBuilder[V, T]) Project(projections ...Projection[V, T]) *ViewBuilder[V, T] {
	for _, p := range projections {
		b.projections = append(b.projections, p.render)
	}
	return b
}

// Where restricts the source rows included in the view. The condition is
// rendered with all values inlined as literals, since a view definition
// cannot carry query parameters.
func (b *ViewBuilder[V, T]) Where(filters ...lib.Filter[T]) *ViewBuilder[V, T] {
	b.where = lib.RenderLiteralFilter(filters...)
	return b
}

// GroupBy groups the source rows before aggregation.
func (b *ViewBuilder[V, T]) GroupBy(keys ...lib.KeyProvider[T]) *ViewBuilder[V, T] {
	for _, k := range keys {
		b.groupBy = append(b.groupBy, lib.RenderProjection(k))
	}
	return b
}

func (b *ViewBuilder[V, T]) viewDef() viewDefJSON {
	return viewDefJSON{
		View:        typeName[V](),
		Source:      typeName[T](),
		Projections: b.projections,
		Where:       b.where,
		GroupBy:     b.groupBy,
	}
}

type viewDefJSON struct {
	View        string   `json:"view"`
	Source      string   `json:"source"`
	Projections []string `json:"projections"`
	Where       string   `json:"where,omitempty"`
	GroupBy     []string `json:"group_by,omitempty"`
}

func typeName[T any]() string {
	return reflect.TypeOf((*T)(nil)).Elem().Name()
}
